{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Derived Skill Profile",
  "type": "object",
  "required": [
    "name",
    "description",
    "targetUser",
    "useWhen",
    "doNotUseWhen"
  ],
  "patternProperties": {
    "^name$": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "^description$": {
      "type": "string",
      "minLength": 80
    },
    "^targetUser$": {
      "type": "string"
    },
    "^useWhen$": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "^doNotUseWhen$": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "^maintenanceCadence$": {
      "type": "string"
    },
    "^assumptions$": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
