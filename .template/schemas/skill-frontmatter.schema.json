{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Skill SKILL.md Frontmatter",
  "type": "object",
  "required": [
    "name",
    "description"
  ],
  "patternProperties": {
    "^name$": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?!.*--)[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
    },
    "^description$": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "^license$": {
      "type": "string",
      "minLength": 1
    },
    "^compatibility$": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "^metadata$": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "^allowed-tools$": {
      "type": "string",
      "minLength": 1
    },
    "^argument-hint$": {
      "type": "string",
      "minLength": 1
    },
    "^user-invocable$": {
      "type": "boolean"
    },
    "^disable-model-invocation$": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
